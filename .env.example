# Confluence MCP Server — environment configuration
# Copy this file to .env and fill in your values.

# ─── Required ───────────────────────────────────────────────────────────────

# Your Atlassian Cloud domain (without trailing slash)
# Example: https://mycompany.atlassian.net
CONFLUENCE_BASE_URL=https://your-domain.atlassian.net

# ─── Authentication (choose one of the two options below) ───────────────────

# Option A — Basic Auth via API Token (recommended for personal use)
# Create a token at: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_EMAIL=your-email@example.com
CONFLUENCE_API_TOKEN=your-api-token-here

# Option B — Bearer / Personal Access Token (PAT)
# Useful for service accounts or when a PAT is already issued.
# When set, this takes priority over Option A.
# CONFLUENCE_BEARER_TOKEN=your-personal-access-token-here
